{
  "name": "mrs",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "concurrently -k \"corepack pnpm --filter client dev\" \"corepack pnpm --filter server dev\"",
    "dev:services": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-reader.ps1",
    "dev:web+services": "concurrently -k \"corepack pnpm run dev:web\" \"corepack pnpm run dev:services\"",
    "dev:all": "concurrently -k \"corepack pnpm -r --parallel dev\" \"powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-reader.ps1\"",
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "dev:electron": "pnpm --filter electron dev",
    "build": "pnpm -r build",
    "build:electron": "pnpm --filter electron build:app",
    "build:electron:installer": "pnpm --filter electron build:installer"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^40.5.0",
    "wait-on": "^9.0.4"
  }
}
